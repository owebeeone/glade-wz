/*
  Provisional local development environment overlay.

  This file is intentionally separate from workspace, application, provider,
  and scale declarations. It answers deployment/admission questions for one
  environment without changing the application semantics.

  In hosted production, a provider-owned import could replace this file with
  stricter namespace admission, public ingress, ACME/DNS proof, provider route
  publication, and managed certificate references.
*/
environment local_dev {
  // Package-scoped canonical id: pkg:griplab#env:local-dev.
  id "env:local-dev"

  // Applies this overlay to the package alias from GripLab.glade.
  applies package griplab

  // Local/dev mode may allow weak local identities. A hosted provider should
  // reject broad wildcards unless its own policy explicitly permits them.
  admission allow package "pkg:griplab"
  admission allow namespace "pkg:local:*"

  // TLS material belongs in environment config as references, not inline
  // private key data. Tooling can provide local defaults such as a generated
  // LAN CA or developer-provided cert/key refs.
  ingress lan_https {
    listen "0.0.0.0:8443"
    accepts join for package griplab

    tls local_team {
      mode local_ca
      certificate ref "secret:local-dev/tls-cert"
      private_key ref "secret:local-dev/tls-key"
      trust_anchor ref "secret:local-dev/root-ca"
    }
  }
}
